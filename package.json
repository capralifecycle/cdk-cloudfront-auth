{
  "name": "@liflig/cdk-cloudfront-auth",
  "version": "0.0.0-development",
  "description": "CDK Constructs for adding authentication for a CloudFront Distribution",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/capralifecycle/cdk-cloudfront-auth"
  },
  "scripts": {
    "build": "bun run build.ts && tsc",
    "watch": "tsc -w",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "check": "biome ci",
    "fix": "biome check --write",
    "prepare": "bun run build && bunx husky",
    "semantic-release": "semantic-release",
    "clean": "rm -rf dist lib",
    "upgrade-deps": "bun update"
  },
  "keywords": [
    "cdk",
    "cloudfront",
    "authentication"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "dist/**/*",
    "lib/**/*"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@aws-sdk/client-lambda": "^3.1005.0",
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/adm-zip": "^0.5.7",
    "@types/aws-lambda": "8.10.161",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.12.2",
    "adm-zip": "^0.5.16",
    "aws-cdk-lib": "2.247.0",
    "axios": "1.14.0",
    "constructs": "10.6.0",
    "cookie": "1.1.1",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-cdk-snapshot": "2.3.6",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa": "3.2.2",
    "semantic-release": "25.0.3",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3"
  },
  "dependencies": {},
  "peerDependencies": {
    "aws-cdk-lib": "^2.0.0"
  },
  "overrides": {
    "minimatch": "10.2.5"
  }
}
